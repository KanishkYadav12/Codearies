# ---------------------------------------------------------------------------
# DevDrops client
#
# Only variables prefixed with VITE_ are exposed to the browser bundle. Never
# put a secret here — everything in this file ships to the client.
# ---------------------------------------------------------------------------

# Base URL of the DevDrops API.
#
# Leave EMPTY for local development: vite.config.js proxies /api to
# http://localhost:5000, so a relative URL is same-origin and cookies just work.
#
# Set it on Vercel to the deployed backend, e.g.
#   VITE_API_URL=https://devdrops-api.onrender.com
VITE_API_URL=
