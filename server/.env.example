# ---------------------------------------------------------------------------
# DevDrops API - environment variables
# Copy to `.env` and fill in. Every variable below is validated on startup;
# the process refuses to boot if a required one is missing or malformed.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=5000

# MongoDB (Atlas connection string or local mongod)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=devdrops

# Auth - use a long random string in production (e.g. `openssl rand -hex 48`)
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# CORS - comma separated list of allowed browser origins
CLIENT_ORIGIN=http://localhost:5173

# Logging - one of: error | warn | info | debug
LOG_LEVEL=debug

# Public base URL of the frontend, used when building shareable collection links
PUBLIC_APP_URL=http://localhost:5173
